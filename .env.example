# ─────────────────────────────────────────────────────────────────────────────
# Snap Pro — environment variables
# Copy this file to `.env.local` for local development.
# Never commit real secrets.
# ─────────────────────────────────────────────────────────────────────────────

# ── Public site origin ──────────────────────────────────────────────────────
# Used by:
#   • app/layout.tsx          (metadataBase for OG/Twitter cards)
#   • app/sitemap.ts          (absolute URLs)
#   • app/robots.ts           (sitemap host)
# Set this for every deployment environment.
NEXT_PUBLIC_SITE_URL=https://snappro.app

# ── Firebase Auth + Firestore ───────────────────────────────────────────────
# The web config below is NOT secret — Firebase web config is meant to be
# public, which is why it's prefixed NEXT_PUBLIC_. Real security comes from
# Firestore Security Rules (see firestore.rules), not from hiding this.
# Leave these blank to run the app with sign-in disabled (no crash — see
# lib/firebase/client.ts). Fill them in from Firebase Console → Project
# settings → General → Your apps → Web app.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Firebase Admin SDK — THIS IS A SECRET. Server-only, never NEXT_PUBLIC_,
# never committed. The full service-account JSON, minified to one line.
# Firebase Console → Project settings → Service accounts → Generate new
# private key. Optional: only needed for server-side Admin operations.
# FIREBASE_SERVICE_ACCOUNT_KEY=

# ── Reserved / future ───────────────────────────────────────────────────────
# Uncomment and fill in as the corresponding feature lands. These are not
# read anywhere in the codebase yet — listed so deployment configs can be
# prepared in advance.

# Analytics (privacy-friendly default; pick one)
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=snappro.app
# NEXT_PUBLIC_POSTHOG_KEY=
# NEXT_PUBLIC_POSTHOG_HOST=https://eu.posthog.com

# Error tracking
# SENTRY_DSN=
# NEXT_PUBLIC_SENTRY_DSN=
# SENTRY_AUTH_TOKEN=
# SENTRY_ORG=
# SENTRY_PROJECT=

# Newsletter (Resend / ConvertKit / Beehiiv — pick one)
# RESEND_API_KEY=
# RESEND_AUDIENCE_ID=
# CONVERTKIT_API_KEY=
# CONVERTKIT_FORM_ID=

# Payments (Stripe)
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Storage (pick one — used when the editor backend lands)
# AWS_S3_BUCKET=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=
# CLOUDFLARE_R2_ACCOUNT_ID=
# CLOUDFLARE_R2_ACCESS_KEY_ID=
# CLOUDFLARE_R2_SECRET_ACCESS_KEY=
# CLOUDFLARE_R2_BUCKET=

# AI providers (pick one or more — used by editor backend)
# OPENAI_API_KEY=
# REPLICATE_API_TOKEN=
# FAL_KEY=
